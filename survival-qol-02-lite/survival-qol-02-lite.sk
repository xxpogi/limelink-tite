options:
    q02-prefix: &8[&bQ02&8]&r

command /q02bio [<text>]:
    description: Records current biome into personal notes. (variant #02)
    trigger:
        set {_p} to "{@q02-prefix}"
        add biome at player to {journal::%player's uuid%::*}
        send "%{_p}% &aLogged biome: &f%biome at player%"
