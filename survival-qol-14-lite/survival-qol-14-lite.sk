options:
    q14-prefix: &8[&bQ14&8]&r

command /q14ore [<text>]:
    description: Tracks ores mined during current session. (variant #14)
    trigger:
        set {_p} to "{@q14-prefix}"
        send "%{_p}% &7Ores this session: &fCoal %{ores::%player's uuid%::coal}% &7Iron %{ores::%player's uuid%::iron}%"
