options:
    q29-prefix: &8[&bQ29&8]&r

command /q29vil [<text>]:
    description: Stores quick notes for villager hall plans. (variant #29)
    trigger:
        set {_p} to "{@q29-prefix}"
        set {villagernote::%player's uuid%} to "Librarian -> Toolsmith -> Armorer"
        send "%{_p}% &aSaved default villager route plan."
