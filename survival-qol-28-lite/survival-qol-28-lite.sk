options:
    q28-prefix: &8[&bQ28&8]&r

command /q28sme [<text>]:
    description: Estimates fuel needed for smelting batches. (variant #28)
    trigger:
        set {_p} to "{@q28-prefix}"
        set {_items} to arg-1 parsed as integer
        if {_items} is not set:
            set {_items} to 64
        send "%{_p}% &7Approx fuel: &f%ceil({_items} / 8)% coal"
